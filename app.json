{
  "expo": {
    "name": "Stacy",
    "slug": "stacy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/stacy-logo-new.png",
    "scheme": "stacy",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0610",
    "ios": {
      "icon": "./assets/images/stacy-logo-new.png",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0610",
        "foregroundImage": "./assets/images/stacy-logo-new.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ebube.anyanwu.stacy"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/stacy-logo-new.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0610",
          "image": "./assets/images/stacy-logo-new.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0A0610",
            "image": "./assets/images/stacy-logo-new.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
